{
  "name": "@agent-harness/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "Agent Harness",
  "description": "Deterministic orchestration shell for LLM agents — smart routing, multi-phase workflows, verification dashboards",
  "publisher": "agent-harness",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "activationEvents": [
    "workspaceContains:harness.config.yaml",
    "workspaceContains:harness.config.yml"
  ],
  "contributes": {
    "commands": [
      {
        "command": "agentHarness.newTask",
        "title": "Harness: New Task",
        "icon": "$(add)"
      },
      {
        "command": "agentHarness.showMenu",
        "title": "Harness: Show Menu"
      },
      {
        "command": "agentHarness.startBackend",
        "title": "Harness: Start Backend",
        "icon": "$(play)"
      },
      {
        "command": "agentHarness.stopBackend",
        "title": "Harness: Stop Backend",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agentHarness.openDashboard",
        "title": "Harness: Open Dashboard",
        "icon": "$(dashboard)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentHarness",
          "title": "Agent Harness",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "agentHarness": [
        {
          "id": "agentHarnessWorkflows",
          "name": "Workflows"
        }
      ]
    },
    "configuration": {
      "title": "Agent Harness",
      "properties": {
        "agentHarness.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter for the backend"
        },
        "agentHarness.backendPort": {
          "type": "number",
          "default": 8321,
          "description": "Port for the Python backend server"
        },
        "agentHarness.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Python backend when harness.config.yaml is detected"
        }
      }
    }
  },
  "dependencies": {
    "@agent-harness/core": "workspace:*",
    "@agent-harness/mcp-client": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "vitest": "^3.0.0"
  }
}
