{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "type": "object",
  "required": ["id", "title", "description", "type", "repo", "createdAt"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["bug-fix", "feature", "refactor", "test", "docs", "review", "custom"]
    },
    "repo": { "type": "string" },
    "branch": { "type": "string" },
    "files": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
